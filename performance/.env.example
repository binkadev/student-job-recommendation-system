# Local-only performance database settings.
# Copy this file to performance/.env before running the scripts.
POSTGRES_DB=student_job_recommendation_perf
POSTGRES_USER=perf_user
POSTGRES_PASSWORD=perf_local_only_password
POSTGRES_PORT=55432
PERF_POSTGRES_CONTAINER=student-job-recommendation-perf-postgres
PERF_POSTGRES_VOLUME=student-job-recommendation-perf-data

# Local-only backend settings used by start-backend.ps1.
SERVER_PORT=8080
APP_JWT_SECRET=local-performance-only-jwt-secret-key-2026-change-me
APP_JWT_EXPIRATION_MS=86400000
HIBERNATE_GENERATE_STATISTICS=false
