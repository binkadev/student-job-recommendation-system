Project student_job_recommendation {
  database_type: 'PostgreSQL'
}

Table users {
  id bigint [pk, increment]
  email varchar(255) [not null, unique]
  password_hash varchar(255) [not null]
  full_name varchar(255) [not null]
  phone varchar(50)
  role varchar(50) [not null]
  status varchar(50) [not null, default: 'ACTIVE']
  last_login_at timestamp
  created_at timestamp [not null, default: `CURRENT_TIMESTAMP`]
  updated_at timestamp [not null, default: `CURRENT_TIMESTAMP`]

  Indexes {
    role [name: 'idx_users_role']
    status [name: 'idx_users_status']
    last_login_at [name: 'idx_users_last_login_at']
  }
}

Table students {
  id bigint [pk, increment]
  user_id bigint [not null, unique]
  student_code varchar(100)
  university varchar(255)
  major varchar(255)
  graduation_year integer
  location varchar(255)
  created_at timestamp [not null, default: `CURRENT_TIMESTAMP`]
  updated_at timestamp [not null, default: `CURRENT_TIMESTAMP`]
}

Table student_profiles {
  id bigint [pk, increment]
  student_id bigint [not null, unique]
  headline varchar(255)
  summary text
  education_level varchar(100)
  gpa numeric(3,2)
  preferred_job_type varchar(50)
  preferred_working_model varchar(50)
  preferred_location varchar(255)
  education text
  experience text
  projects text
  target_position varchar(255)
  raw_text text
  processed_text text
  profile_completeness integer [not null, default: 0]
  created_at timestamp [not null, default: `CURRENT_TIMESTAMP`]
  updated_at timestamp [not null, default: `CURRENT_TIMESTAMP`]
}

Table companies {
  id bigint [pk, increment]
  user_id bigint [not null, unique]
  company_name varchar(255) [not null]
  tax_code varchar(100)
  website_url varchar(500)
  logo_url varchar(500)
  industry varchar(150)
  company_size varchar(100)
  description text
  address text
  phone varchar(50)
  status varchar(50) [not null, default: 'PENDING']
  created_at timestamp [not null, default: `CURRENT_TIMESTAMP`]
  updated_at timestamp [not null, default: `CURRENT_TIMESTAMP`]

  Indexes {
    status [name: 'idx_companies_status']
    company_name [name: 'idx_companies_company_name']
  }
}

Table skills {
  id bigint [pk, increment]
  name varchar(150) [not null, unique]
  normalized_name varchar(150)
  category varchar(100)
  description text
  created_at timestamp [not null, default: `CURRENT_TIMESTAMP`]
  updated_at timestamp [not null, default: `CURRENT_TIMESTAMP`]

  Indexes {
    category [name: 'idx_skills_category']
    normalized_name [unique, name: 'uk_skills_normalized_name']
  }
}

Table student_skills {
  id bigint [pk, increment]
  student_id bigint [not null]
  skill_id bigint [not null]
  level varchar(50) [not null]
  source varchar(50) [not null]
  years_of_experience numeric(4,1)
  created_at timestamp [not null, default: `CURRENT_TIMESTAMP`]
  updated_at timestamp [not null, default: `CURRENT_TIMESTAMP`]

  Indexes {
    (student_id, skill_id) [unique, name: 'uk_student_skills_student_skill']
    skill_id [name: 'idx_student_skills_skill_id']
  }
}

Table jobs {
  id bigint [pk, increment]
  company_id bigint [not null]
  title varchar(255) [not null]
  description text [not null]
  requirements text
  benefits text
  location varchar(255)
  job_type varchar(50) [not null]
  working_model varchar(50) [not null]
  status varchar(50) [not null, default: 'DRAFT']
  salary_min numeric(14,2)
  salary_max numeric(14,2)
  currency varchar(10)
  deadline date
  published_at timestamp
  closed_at timestamp
  created_at timestamp [not null, default: `CURRENT_TIMESTAMP`]
  updated_at timestamp [not null, default: `CURRENT_TIMESTAMP`]

  Indexes {
    company_id [name: 'idx_jobs_company_id']
    status [name: 'idx_jobs_status']
    job_type [name: 'idx_jobs_job_type']
    working_model [name: 'idx_jobs_working_model']
    deadline [name: 'idx_jobs_deadline']
  }
}

Table job_skills {
  id bigint [pk, increment]
  job_id bigint [not null]
  skill_id bigint [not null]
  importance varchar(50) [not null]
  min_level varchar(50)
  created_at timestamp [not null, default: `CURRENT_TIMESTAMP`]
  updated_at timestamp [not null, default: `CURRENT_TIMESTAMP`]

  Indexes {
    (job_id, skill_id) [unique, name: 'uk_job_skills_job_skill']
    skill_id [name: 'idx_job_skills_skill_id']
  }
}

Table saved_jobs {
  id bigint [pk, increment]
  student_id bigint [not null]
  job_id bigint [not null]
  created_at timestamp [not null, default: `CURRENT_TIMESTAMP`]
  updated_at timestamp [not null, default: `CURRENT_TIMESTAMP`]

  Indexes {
    (student_id, job_id) [unique, name: 'uk_saved_jobs_student_job']
    job_id [name: 'idx_saved_jobs_job_id']
  }
}

Table cv_files {
  id bigint [pk, increment]
  student_id bigint [not null]
  file_name varchar(255) [not null]
  original_file_name varchar(255)
  stored_file_name varchar(255)
  file_url varchar(500) [not null]
  file_path varchar(500)
  content_type varchar(100)
  file_size bigint
  extracted_text text
  processed_text text
  is_active boolean [not null, default: false]
  uploaded_at timestamp [not null, default: `CURRENT_TIMESTAMP`]
  created_at timestamp [not null, default: `CURRENT_TIMESTAMP`]
  updated_at timestamp [not null, default: `CURRENT_TIMESTAMP`]

  Note: 'Partial unique index uk_cv_files_student_active on student_id where is_active = TRUE.'

  Indexes {
    student_id [name: 'idx_cv_files_student_id']
  }
}

Table applications {
  id bigint [pk, increment]
  student_id bigint [not null]
  job_id bigint [not null]
  cv_file_id bigint
  status varchar(50) [not null, default: 'PENDING']
  cover_letter text
  applied_at timestamp [not null, default: `CURRENT_TIMESTAMP`]
  reviewed_at timestamp
  created_at timestamp [not null, default: `CURRENT_TIMESTAMP`]
  updated_at timestamp [not null, default: `CURRENT_TIMESTAMP`]

  Indexes {
    (student_id, job_id) [unique, name: 'uk_applications_student_job']
    student_id [name: 'idx_applications_student_id']
    job_id [name: 'idx_applications_job_id']
    status [name: 'idx_applications_status']
  }
}

Table recommendation_runs {
  id bigint [pk, increment]
  student_id bigint [not null]
  cv_file_id bigint
  source_type varchar(50) [not null]
  status varchar(50) [not null]
  started_at timestamp [not null, default: `CURRENT_TIMESTAMP`]
  finished_at timestamp
  error_message text
  created_at timestamp [not null, default: `CURRENT_TIMESTAMP`]
  updated_at timestamp [not null, default: `CURRENT_TIMESTAMP`]

  Indexes {
    student_id [name: 'idx_recommendation_runs_student_id']
    status [name: 'idx_recommendation_runs_status']
  }
}

Table recommendation_results {
  id bigint [pk, increment]
  run_id bigint [not null]
  job_id bigint [not null]
  score numeric(8,5) [not null]
  matched_keywords jsonb
  rank_position integer [not null]
  created_at timestamp [not null, default: `CURRENT_TIMESTAMP`]
  updated_at timestamp [not null, default: `CURRENT_TIMESTAMP`]

  Indexes {
    (run_id, job_id) [unique, name: 'uk_recommendation_results_run_job']
    job_id [name: 'idx_recommendation_results_job_id']
    score [name: 'idx_recommendation_results_score']
  }
}

Table notifications {
  id bigint [pk, increment]
  user_id bigint [not null]
  type varchar(50) [not null]
  title varchar(255) [not null]
  message text [not null]
  reference_type varchar(50)
  reference_id bigint
  is_read boolean [not null, default: false]
  read_at timestamp
  created_at timestamp [not null, default: `CURRENT_TIMESTAMP`]
  updated_at timestamp [not null, default: `CURRENT_TIMESTAMP`]

  Indexes {
    user_id [name: 'idx_notifications_user_id']
    (user_id, is_read) [name: 'idx_notifications_user_read']
    created_at [name: 'idx_notifications_created_at']
  }
}

Ref: students.user_id > users.id [delete: restrict]
Ref: student_profiles.student_id > students.id [delete: restrict]
Ref: companies.user_id > users.id [delete: restrict]
Ref: student_skills.student_id > students.id [delete: restrict]
Ref: student_skills.skill_id > skills.id [delete: restrict]
Ref: jobs.company_id > companies.id [delete: restrict]
Ref: job_skills.job_id > jobs.id [delete: restrict]
Ref: job_skills.skill_id > skills.id [delete: restrict]
Ref: saved_jobs.student_id > students.id [delete: restrict]
Ref: saved_jobs.job_id > jobs.id [delete: restrict]
Ref: cv_files.student_id > students.id [delete: restrict]
Ref: applications.student_id > students.id [delete: restrict]
Ref: applications.job_id > jobs.id [delete: restrict]
Ref: applications.cv_file_id > cv_files.id [delete: restrict]
Ref: recommendation_runs.student_id > students.id [delete: restrict]
Ref: recommendation_runs.cv_file_id > cv_files.id [delete: restrict]
Ref: recommendation_results.run_id > recommendation_runs.id [delete: restrict]
Ref: recommendation_results.job_id > jobs.id [delete: restrict]
Ref: notifications.user_id > users.id [delete: restrict]
